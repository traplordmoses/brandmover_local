# --- LLM Provider ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Image Generation (Replicate) ---
REPLICATE_API_TOKEN=
IMAGE_MODEL=auto                # "auto" routes by content type, or force a specific model:
                                # black-forest-labs/flux-1.1-pro (default/general)
                                # google/nano-banana-pro (text overlays/announcements)
                                # recraft-ai/recraft-v3-svg (brand assets/icons)
                                # bytedance/seedream-4.5 (lifestyle/photography)

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# --- X / Twitter ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# --- Brand ---
BRAND_FOLDER=./brand
BRAND_NAME=MyBrand

# --- Pipeline ---
PIPELINE_MODE=full          # "full" (4-step) or "fast" (3-step, merges plan+verify)
MAX_REFERENCE_CHARS=50000   # max chars loaded from brand/references/

# --- Agent Mode ---
AGENT_MODE=pipeline         # "pipeline" (existing 4-step) or "agent" (Claude tool-use loop)
AGENT_MAX_TURNS=15
AGENT_MODEL=claude-sonnet-4-6
FEEDBACK_SUMMARIZE_EVERY=10

# --- Figma ---
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=                 # Your Figma file key (from the URL: figma.com/file/<KEY>/...)
FIGMA_NODE_ID=                  # Node ID to fetch tokens from (e.g. "0:5")
